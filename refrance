<script>
  // ---------- Navbar scroll state ----------
  const navbar = document.getElementById('navbar');
  const brandTop = document.getElementById('brandTop');
  const navlinks = document.getElementById('navlinks');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar.style.background = 'rgba(10,43,32,0.92)';
      navbar.style.backdropFilter = 'blur(14px)';
      navbar.style.borderBottom = '1px solid rgba(212,175,55,0.2)';
    } else {
      navbar.style.background = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  });

  // ---------- Mobile menu ----------
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-link').forEach(l => {
    l.addEventListener('click', () => mobileMenu.classList.add('hidden'));
  });

  // ---------- Scroll reveal ----------
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  revealEls.forEach(el => io.observe(el));

  // ---------- Animated counters ----------
  const counters = document.querySelectorAll('.counter');
  const counterIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target;
        if (el.dataset.static) {
          el.textContent = el.dataset.static;
        } else {
          const target = parseInt(el.dataset.target, 10);
          const suffix = el.dataset.suffix || '';
          let cur = 0;
          const step = Math.max(1, Math.round(target / 40));
          const iv = setInterval(() => {
            cur += step;
            if (cur >= target) { cur = target; clearInterval(iv); }
            el.textContent = cur + suffix;
          }, 30);
        }
        counterIO.unobserve(el);
      }
    });
  }, { threshold: 0.4 });
  counters.forEach(c => counterIO.observe(c));

  // ---------- Before/After slider ----------
  const baSlider = document.getElementById('baSlider');
  const baAfterWrap = document.getElementById('baAfterWrap');
  const baHandle = document.getElementById('baHandle');
  let dragging = false;

  function setSlider(clientX){
    const rect = baSlider.getBoundingClientRect();
    let pct = ((clientX - rect.left) / rect.width) * 100;
    pct = Math.max(0, Math.min(100, pct));
    baAfterWrap.style.width = pct + '%';
    baHandle.style.left = pct + '%';
  }
  baHandle.addEventListener('mousedown', () => dragging = true);
  window.addEventListener('mouseup', () => dragging = false);
  window.addEventListener('mousemove', (e) => { if (dragging) setSlider(e.clientX); });
  baHandle.addEventListener('touchstart', () => dragging = true, {passive:true});
  window.addEventListener('touchend', () => dragging = false);
  window.addEventListener('touchmove', (e) => { if (dragging && e.touches[0]) setSlider(e.touches[0].clientX); }, {passive:true});
  baSlider.addEventListener('click', (e) => setSlider(e.clientX));

  // ---------- Cost Estimator ----------
  const propType = document.getElementById('propType');
  const areaRange = document.getElementById('areaRange');
  const areaVal = document.getElementById('areaVal');
  const chkKitchen = document.getElementById('chkKitchen');
  const chkWardrobe = document.getElementById('chkWardrobe');
  const chkCeiling = document.getElementById('chkCeiling');
  const estimateOutput = document.getElementById('estimateOutput');

  function formatLakh(v){
    return '₹ ' + (v/100000).toFixed(1) + 'L';
  }

  function calcEstimate(){
    const area = parseInt(areaRange.value, 10);
    areaVal.textContent = area;
    const baseRateLow = 1400;   // per sqft, low
    const baseRateHigh = 2100;  // per sqft, high
    let low = area * baseRateLow;
    let high = area * baseRateHigh;

    if (chkKitchen.checked) { low += 180000; high += 320000; }
    if (chkWardrobe.checked) { low += 90000; high += 160000; }
    if (chkCeiling.checked) { low += 60000; high += 110000; }

    estimateOutput.textContent = formatLakh(low) + ' – ' + formatLakh(high);
  }
  [propType, areaRange, chkKitchen, chkWardrobe, chkCeiling].forEach(el => {
    el.addEventListener('input', calcEstimate);
    el.addEventListener('change', calcEstimate);
  });
  calcEstimate();

  // ---------- Lead form ----------
  function handleLeadSubmit(e){
    e.preventDefault();
    document.getElementById('leadSuccess').classList.remove('hidden');
    e.target.reset();
    return false;
  }

  // ---------- Testimonial marquee pause on hover ----------
  const testiTrack = document.getElementById('testiTrack');
  testiTrack.addEventListener('mouseenter', () => testiTrack.style.animationPlayState = 'paused');
  testiTrack.addEventListener('mouseleave', () => testiTrack.style.animationPlayState = 'running');
</script>

